# Application Configuration
PORT=55572

# Redis Configuration
# Use 'redis' for Docker networking (docker-compose service name)
# For local development, use 'localhost'
REDIS_ADDR=redis
REDIS_PORT=6379

# LLM Provider Configuration
# Gemini API Key - Get from https://ai.google.dev/
# Leave empty to disable Gemini provider
GEMINI_API_KEY=your-api-key-here

# Data Directory - for storing documents and RAG data
DATA_DIR=/app/data

# ChromaDB Configuration (For Phase 2 RAG integration)
# URL is docker-compose internal network address
# When running locally without Docker, use: http://localhost:8000
CHROMADB_URL=http://chromadb:8000
RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=50